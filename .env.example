# App
NODE_ENV=development
APP_URL=http://localhost:25173
FRONTEND_PORT=25173

# Gateway
GATEWAY_PORT=3000
GATEWAY_HOST_PORT=23000
MS_ASSINATURA_PORT=3001
MS_ASSINATURA_HOST_PORT=23001
MS_DOCUMENTO_PORT=3002
MS_DOCUMENTO_HOST_PORT=23002
MS_SELFIE_DOCUMENTO_PORT=3004
MS_SELFIE_DOCUMENTO_HOST_PORT=23004
JWT_SECRET=change-me

# Security
GATEWAY_URL=http://gateway:3000
HMAC_SHARED_SECRET=change-this-secret
REQUIRE_HMAC=false

# PostgreSQL
POSTGRES_DB=bluetech_sign
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=25432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/bluetech_sign
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000
PG_SSL_MODE=disable
ADMINER_HOST_PORT=28080

# Redis
REDIS_PORT=6379
REDIS_HOST_PORT=26379
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=local-minio-key
MINIO_ROOT_PASSWORD=local-minio-secret
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_HOST_PORT=29000
MINIO_CONSOLE_HOST_PORT=29001
MINIO_USE_SSL=false
BUCKET_ASSINATURAS=bluetech-sign
ASSINATURAS_PREFIX=assinatura
REVERSE_GEOCODE_ENABLED=true
REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
REVERSE_GEOCODE_USER_AGENT=BlueTechSign/1.0
IP_GEOLOOKUP_ENABLED=true
IP_GEOLOOKUP_URL_TEMPLATE=http://ip-api.com/json/{ip}?fields=status,message,country,regionName,city,lat,lon,query
PUBLIC_IP_LOOKUP_URL=https://api.ipify.org?format=json
BUCKET_DOCUMENTOS=bluetech-sign
DOCUMENTOS_PREFIX=documento
BUCKET_SELFIES=bluetech-sign
SELFIES_PREFIX=selfie_documento

# Validator
VALIDATOR_PORT=8000
VALIDATOR_HOST_PORT=28000
VALIDATOR_URL=http://ms-validator:8000

# External
BLUEPOINT_API_URL=https://bluepoint-api.bluetechfilms.com.br
VITE_GATEWAY_URL=http://localhost:23000
VITE_ASSINATURA_URL=http://localhost:23001
VITE_DOCUMENTO_URL=http://localhost:23002
VITE_SELFIE_DOCUMENTO_URL=http://localhost:23004
VITE_VALIDATOR_URL=http://localhost:28000
