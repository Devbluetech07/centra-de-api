# App
NODE_ENV=development
PORT=3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=valeris
DB_USER=valeris
DB_PASSWORD=CHANGE_ME_DB_PASSWORD_32_CHARS_MIN

# JWT (required, min 32 chars)
JWT_SECRET=CHANGE_ME_JWT_SECRET_32_CHARS_MIN

# CORS
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD_32_CHARS_MIN
MINIO_USE_SSL=false
MINIO_PUBLIC_BUCKET=false

# Integration and demo mode
TOKEN_ONLY_MODE=false
INTEGRATION_TOKENS=
ALLOW_PORTAL_DEMO_TOKEN=false
PORTAL_DEMO_TOKEN=CHANGE_ME_PORTAL_DEMO_TOKEN
